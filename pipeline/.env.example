## Provider selection
TNM_NEWS_PROVIDER=gnews

## Provider API keys
TNM_NEWSAPI_KEY=
TNM_GNEWS_KEY=
TNM_MEDIASTACK_KEY=

## Optional custom provider base URLs
TNM_NEWSAPI_BASE_URL=https://newsapi.org/v2
TNM_GNEWS_BASE_URL=https://gnews.io/api/v4
TNM_MEDIASTACK_BASE_URL=http://api.mediastack.com/v1

## LLM placeholders (for future integration)
TNM_LLM_PROVIDER=placeholder
TNM_LLM_API_KEY=
TNM_LLM_MODEL=placeholder-model

## Signing + output handoff
TNM_KEYS_DIR=./keys
TNM_ARTICLES_DIR=./articles
TNM_PIPELINE_OUTPUT_PATH=./pipeline/output/latest-meta-article.json

## Enable signing after local run:
## TNM_HANDOFF_SIGN=1 node ./pipeline/run-local.mjs
